import { Theme } from "../theme.slint";
import { FluentIcon } from "../icons.slint";
import { ComboBox } from "combo_box.slint";
import { CheckBox } from "checkbox.slint";
import { TextField } from "text_field.slint";

export component RuleRow inherits Rectangle {
    in property <[string]> app-names: [];
    in property <[string]> action-names: [];
    in property <bool> show-glob: true;
    in property <bool> show-host: true;
    in property <bool> show-url: true;
    in property <bool> show-modifier: true;
    in-out property <string> glob: "";
    in-out property <string> host: "";
    in-out property <string> url: "";
    in-out property <string> modifier: "";
    in-out property <string> app: "";
    in-out property <bool> pick: false;
    callback move-up();
    callback move-down();
    callback delete();
    callback edited(string, string, string, string, string, bool);

    min-height: 96px;
    border-radius: Theme.radius-control * 1px;
    background: Theme.current.control-secondary;
    border-width: 1px;
    border-color: Theme.current.control-stroke;

    HorizontalLayout {
        padding-top: 12px;
        padding-bottom: 12px;
        padding-left: Theme.spacing-m * 1px;
        padding-right: Theme.spacing-m * 1px;
        spacing: Theme.spacing-m * 1px;
        
        VerticalLayout {
            spacing: Theme.spacing-s * 1px;
            
            // 条件 (WHEN)
            HorizontalLayout {
                spacing: Theme.spacing-s * 1px;
                
                Text {
                    text: "条件 (WHEN):";
                    font-family: Theme.font-family;
                    font-size: 12px;
                    font-weight: 600;
                    color: Theme.current.text-secondary;
                    vertical-alignment: center;
                    width: 90px;
                }
                
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;
                    
                    // 1行目: パス/ホスト ＋ キー
                    HorizontalLayout {
                        spacing: Theme.spacing-s * 1px;
                        
                        if (root.show-glob) : HorizontalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "パス:"; width: 40px; font-family: Theme.font-family; font-size: 12px; color: Theme.current.text-tertiary; vertical-alignment: center; }
                            TextField {
                                placeholder: "**/*.md";
                                value <=> root.glob;
                                horizontal-stretch: 1;
                                min-width: 80px;
                                accepted(v) => { root.glob = v; root.edited(root.glob, root.host, root.url, root.modifier, root.app, root.pick); }
                            }
                        }
                        
                        if (root.show-host) : HorizontalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "ホスト:"; width: 40px; font-family: Theme.font-family; font-size: 12px; color: Theme.current.text-tertiary; vertical-alignment: center; }
                            TextField {
                                placeholder: "*.example.com";
                                value <=> root.host;
                                horizontal-stretch: 1;
                                min-width: 80px;
                                accepted(v) => { root.host = v; root.edited(root.glob, root.host, root.url, root.modifier, root.app, root.pick); }
                            }
                        }
                        
                        if (root.show-modifier) : HorizontalLayout {
                            spacing: 4px;
                            horizontal-stretch: 0;
                            Text { text: "キー:"; width: 40px; font-family: Theme.font-family; font-size: 12px; color: Theme.current.text-tertiary; vertical-alignment: center; }
                            ComboBox {
                                model: ["", "SHIFT", "CTRL", "ALT"];
                                current-value: root.modifier;
                                width: 80px;
                                selected(v) => { root.modifier = v; root.edited(root.glob, root.host, root.url, root.modifier, root.app, root.pick); }
                            }
                        }
                    }
                    
                    // 2行目: URL (プロトコル設定時のみ表示)
                    if (root.show-url) : HorizontalLayout {
                        spacing: 4px;
                        horizontal-stretch: 1;
                        Text { text: "URL:"; width: 40px; font-family: Theme.font-family; font-size: 12px; color: Theme.current.text-tertiary; vertical-alignment: center; }
                        TextField {
                            placeholder: "https://*";
                            value <=> root.url;
                            horizontal-stretch: 1;
                            min-width: 120px;
                            accepted(v) => { root.url = v; root.edited(root.glob, root.host, root.url, root.modifier, root.app, root.pick); }
                        }
                    }
                }
            }
            
            // アクション (THEN)
            HorizontalLayout {
                spacing: Theme.spacing-s * 1px;
                alignment: start;
                
                Text {
                    text: "動作 (THEN):";
                    font-family: Theme.font-family;
                    font-size: 12px;
                    font-weight: 600;
                    color: Theme.current.text-secondary;
                    vertical-alignment: center;
                    width: 90px;
                }
                
                Rectangle {
                    width: 36px;
                }
                
                ComboBox {
                    model: root.action-names;
                    current-value: root.pick ? "アプリ選択画面を表示 (Pick)" : root.app;
                    width: 240px;
                    selected(v) => {
                        if (v == "アプリ選択画面を表示 (Pick)") {
                            root.pick = true;
                            root.app = "";
                        } else {
                            root.pick = false;
                            root.app = v;
                        }
                        root.edited(root.glob, root.host, root.url, root.modifier, root.app, root.pick);
                    }
                }
            }
        }
        
        // 操作ボタン
        VerticalLayout {
            width: 32px;
            spacing: 2px;
            alignment: center;
            Rectangle {
                width: 28px;
                height: 24px;
                border-radius: Theme.radius-control * 1px;
                background: up-area.has-hover ? Theme.current.nav-hover-reveal : transparent;
                up-area := TouchArea { clicked => { root.move-up(); } }
                Text {
                    text: FluentIcon.chevron-up;
                    font-family: "Segoe MDL2 Assets";
                    font-size: 11px;
                    color: Theme.current.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            Rectangle {
                width: 28px;
                height: 24px;
                border-radius: Theme.radius-control * 1px;
                background: down-area.has-hover ? Theme.current.nav-hover-reveal : transparent;
                down-area := TouchArea { clicked => { root.move-down(); } }
                Text {
                    text: FluentIcon.chevron-down;
                    font-family: "Segoe MDL2 Assets";
                    font-size: 11px;
                    color: Theme.current.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            Rectangle {
                width: 28px;
                height: 24px;
                border-radius: Theme.radius-control * 1px;
                background: del-area.has-hover ? Theme.current.system-critical : transparent;
                del-area := TouchArea { clicked => { root.delete(); } }
                Text {
                    text: FluentIcon.delete;
                    font-family: "Segoe MDL2 Assets";
                    font-size: 11px;
                    color: del-area.has-hover ? white : Theme.current.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

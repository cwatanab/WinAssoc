export struct CandidateData {
    name: string,
    label: string,
}

export component Picker inherits Window {
    no-frame: true;
    always-on-top: true;
    title: "winassoc";
    background: #00000000;
    width: 300px;
    height: 300px;

    in-out property <string> target-label: " を開くアプリを選択";
    in property <[CandidateData]> candidates: [];
    in property <[image]> icons: [];
    in-out property <int> selected: 0;
    in property <brush> panel-color: #181a20d7;
    in property <brush> text-color: #ebebeb;
    in property <brush> subtle-color: #a0a0a0;
    in property <brush> accent-color: #60a5fa;

    callback choose(int);
    callback cancel();

    forward-focus: focus-area;

    focus-area := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.cancel()
            }
            if (event.text == Key.Return) {
                root.choose(root.selected)
            }
            if (event.text == Key.RightArrow && root.candidates.length > 0) {
                root.selected = Math.mod(root.selected + 1, root.candidates.length)
            }
            if (event.text == Key.LeftArrow && root.candidates.length > 0) {
                root.selected = Math.mod(root.selected + root.candidates.length - 1, root.candidates.length)
            }
            if (event.text == Key.Digit1) {
                root.choose(0)
            }
            if (event.text == Key.Digit2) {
                root.choose(1)
            }
            if (event.text == Key.Digit3) {
                root.choose(2)
            }
            if (event.text == Key.Digit4) {
                root.choose(3)
            }
            if (event.text == Key.Digit5) {
                root.choose(4)
            }
            if (event.text == Key.Digit6) {
                root.choose(5)
            }
            if (event.text == Key.Digit7) {
                root.choose(6)
            }
            if (event.text == Key.Digit8) {
                root.choose(7)
            }
            if (event.text == Key.Digit9) {
                root.choose(8)
            }
            accept
        }

        Rectangle {
            background: root.panel-color;
            border-radius: 12px;
            VerticalLayout {
                padding: 18px;
                spacing: 12px;
                Text {
                    text: root.target-label;
                    color: root.subtle-color;
                    font-size: 10px;
                }
                Rectangle {
                    height: root.height - 60px;
                }
            }
        }
    }
}

component SidebarItem {
    in property <string> text;
    preferred-height: 40px;
    Rectangle {
        TouchArea {
            Text {
                text: root.text;
                font-size: 14px;
                vertical-alignment: center;
                horizontal-alignment: left;
            }
        }
    }
}

export component Settings inherits Window {
    preferred-width: 960px;
    preferred-height: 680px;
    title: "WinAssoc 設定";

    in-out property <bool> dirty: false;
    in property <string> config-path: "";

    callback apply();
    callback unregister();
    callback doctor();
    callback backup();
    callback restore();
    callback save-config();

    VerticalLayout {
        HorizontalLayout {
            Rectangle {
                width: 180px;
                background: #f3f3f3;
                VerticalLayout {
                    padding: 0;
                    SidebarItem { text: "アプリ"; }
                    SidebarItem { text: "拡張子"; }
                    SidebarItem { text: "プロトコル"; }
                    SidebarItem { text: "管理"; }
                }
            }
            Rectangle {
                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;
                    Text {
                        text: "WinAssoc 設定";
                        font-size: 22px;
                        font-weight: 700;
                    }
                    Text {
                        text: "左のメニューから編集する項目を選択してください。";
                        font-size: 13px;
                        color: #888888;
                    }
                }
            }
        }
        Rectangle {
            height: 32px;
            background: #f9f9f9;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 4px;
                padding-bottom: 4px;
                Text {
                    text: root.config-path;
                    font-size: 11px;
                    color: #999999;
                }
                Text {
                    text: root.dirty ? " (未保存)" : " (保存済)";
                    font-size: 11px;
                    color: root.dirty ? #e08000 : #88aa88;
                }
            }
        }
    }
}

export struct CandidateData {
    name: string,
    label: string,
}

export struct AppEntry {
    name: string,
    cmd: string,
    args: string,
    label: string,
}

export struct RouteEntry {
    key: string,
    default: string,
    candidates: string,
    rules_summary: string,
}

export component Picker inherits Window {
    no-frame: true;
    always-on-top: true;
    title: "winassoc";
    background: #00000000;
    width: 300px;
    height: 300px;

    in-out property <string> target-label: " を開くアプリを選択";
    in property <[CandidateData]> candidates: [];
    in property <[image]> icons: [];
    in-out property <int> selected: 0;
    in property <brush> panel-color: #181a20d7;
    in property <brush> text-color: #ebebeb;
    in property <brush> subtle-color: #a0a0a0;
    in property <brush> accent-color: #60a5fa;

    callback choose(int);
    callback cancel();

    forward-focus: focus-area;

    focus-area := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.cancel() }
            if (event.text == Key.Return) { root.choose(root.selected) }
            if (event.text == Key.RightArrow && root.candidates.length > 0) {
                root.selected = Math.mod(root.selected + 1, root.candidates.length)
            }
            if (event.text == Key.LeftArrow && root.candidates.length > 0) {
                root.selected = Math.mod(root.selected + root.candidates.length - 1, root.candidates.length)
            }
            if (event.text == Key.Digit1) { root.choose(0) }
            if (event.text == Key.Digit2) { root.choose(1) }
            if (event.text == Key.Digit3) { root.choose(2) }
            if (event.text == Key.Digit4) { root.choose(3) }
            if (event.text == Key.Digit5) { root.choose(4) }
            if (event.text == Key.Digit6) { root.choose(5) }
            if (event.text == Key.Digit7) { root.choose(6) }
            if (event.text == Key.Digit8) { root.choose(7) }
            if (event.text == Key.Digit9) { root.choose(8) }
            accept
        }

        Rectangle {
            background: root.panel-color;
            border-radius: 12px;
            VerticalLayout {
                padding: 18px;
                spacing: 8px;
                Text {
                    text: root.target-label;
                    color: root.subtle-color;
                    font-size: 12px;
                }
                Rectangle {
                    VerticalLayout {
                        spacing: 8px;
                        for tile[i] in root.candidates: Rectangle {
                            background: root.selected == i ? root.accent-color.with-alpha(0.2) : #00000000;
                            border-radius: 6px;
                            min-height: 32px;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                padding-top: 6px;
                                padding-bottom: 6px;
                                spacing: 10px;
                                if (i < root.icons.length) : Image {
                                    source: root.icons[i];
                                    preferred-width: 24px;
                                    preferred-height: 24px;
                                }
                                VerticalLayout {
                                    Text {
                                        text: tile.name;
                                        font-size: 14px;
                                        color: root.text-color;
                                    }
                                    if (tile.label != "") : Text {
                                        text: tile.label;
                                        font-size: 10px;
                                        color: root.subtle-color;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

enum Page { apps, extensions, protocols, management }

component SidebarButton {
    in property <string> text;
    in property <bool> active: false;
    callback clicked();
    preferred-height: 40px;
    Rectangle {
        background: root.active ? #ddedff : #00000000;
        TouchArea {
            clicked => { root.clicked(); }
            Text {
                text: root.text;
                font-size: 14px;
                vertical-alignment: center;
                horizontal-alignment: left;
                color: root.active ? #1060d0 : #333333;
            }
        }
    }
}

component ActionButton {
    in property <string> text;
    in property <bool> primary: false;
    callback clicked();
    preferred-height: 32px;
    min-width: 140px;
    Rectangle {
        background: root.primary ? #1060d0 : #e0e0e0;
        border-radius: 4px;
        TouchArea {
            clicked => { root.clicked(); }
            Text {
                text: root.text;
                font-size: 13px;
                color: root.primary ? #ffffff : #333333;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component AppsPageContainer {
    callback add-app();
    callback delete-app(int);
    callback update-app(int, string, string, string, string);

    HorizontalLayout {
        spacing: 16px;
        Rectangle {
            width: 200px;
            VerticalLayout {
                spacing: 8px;
                Text { text: "アプリ一覧"; font-size: 16px; font-weight: 600; }
                ActionButton { text: "+ 追加"; clicked => { root.add-app(); } }
                Rectangle { height: 1px; background: #e0e0e0; }
                Rectangle {
                    VerticalLayout {
                        padding-top: 4px;
                        padding-bottom: 4px;
                        Text {
                            text: "追加/削除は左のリストから行います。";
                            color: #888888;
                            font-size: 12px;
                        }
                        Text {
                            text: "詳細編集は右のフォームで行います。";
                            color: #888888;
                            font-size: 12px;
                        }
                    }
                }
            }
        }
        Rectangle { width: 1px; background: #e0e0e0; }
        Rectangle {
            VerticalLayout {
                spacing: 12px;
                Text { text: "アプリ編集"; font-size: 16px; font-weight: 600; }
                Text {
                    text: "アプリの追加・編集は将来実装予定です。";
                    color: #888888;
                    font-size: 13px;
                }
            }
        }
    }
}

component ExtensionsPage {
    VerticalLayout {
        spacing: 16px;
        Text { text: "拡張子ルート"; font-size: 18px; font-weight: 700; }
        Rectangle { height: 1px; background: #e0e0e0; }
        Rectangle {
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "一覧表示のみ。編集は config.toml を直接編集してください。";
                    font-size: 13px;
                    color: #888888;
                }
            }
        }
    }
}

component ProtocolsPage {
    VerticalLayout {
        spacing: 16px;
        Text { text: "プロトコルルート"; font-size: 18px; font-weight: 700; }
        Rectangle { height: 1px; background: #e0e0e0; }
        Rectangle {
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "一覧表示のみ。編集は config.toml を直接編集してください。";
                    font-size: 13px;
                    color: #888888;
                }
            }
        }
    }
}

component ManagementPage {
    in-out property <bool> dirty;
    callback apply();
    callback unregister();
    callback doctor();
    callback backup();
    callback restore();
    callback save-config();

    VerticalLayout {
        spacing: 16px;
        Text { text: "管理"; font-size: 18px; font-weight: 700; }
        Rectangle { height: 1px; background: #e0e0e0; }
        HorizontalLayout {
            spacing: 12px;
            ActionButton { text: "保存"; primary: root.dirty; clicked => { root.save-config(); } }
        }
        Rectangle { height: 1px; background: #e0e0e0; }
        Text { text: "レジストリ操作"; font-size: 15px; font-weight: 600; }
        HorizontalLayout {
            spacing: 12px;
            ActionButton { text: "適用 (apply)"; clicked => { root.apply(); } }
            ActionButton { text: "解除 (unregister)"; clicked => { root.unregister(); } }
            ActionButton { text: "診断 (doctor)"; clicked => { root.doctor(); } }
        }
        Text { text: "バックアップ"; font-size: 15px; font-weight: 600; }
        HorizontalLayout {
            spacing: 12px;
            ActionButton { text: "バックアップ"; clicked => { root.backup(); } }
            ActionButton { text: "復元 (restore)"; clicked => { root.restore(); } }
        }
    }
}

export component Settings inherits Window {
    preferred-width: 960px;
    preferred-height: 680px;
    title: "WinAssoc 設定";

    in-out property <Page> current-page: Page.apps;
    in-out property <bool> dirty: false;
    in property <string> config-path: "";
    in property <[AppEntry]> apps: [];
    in property <[RouteEntry]> exts: [];
    in property <[RouteEntry]> protocols: [];
    in-out property <int> selected-app: -1;

    callback apply();
    callback unregister();
    callback doctor();
    callback backup();
    callback restore();
    callback save-config();

    callback add-app();
    callback delete-app(int);

    VerticalLayout {
        HorizontalLayout {
            Rectangle {
                width: 180px;
                background: #f3f3f3;
                VerticalLayout {
                    padding: 8px;
                    SidebarButton { text: "アプリ"; active: root.current-page == Page.apps; clicked => { root.current-page = Page.apps; } }
                    SidebarButton { text: "拡張子"; active: root.current-page == Page.extensions; clicked => { root.current-page = Page.extensions; } }
                    SidebarButton { text: "プロトコル"; active: root.current-page == Page.protocols; clicked => { root.current-page = Page.protocols; } }
                    SidebarButton { text: "管理"; active: root.current-page == Page.management; clicked => { root.current-page = Page.management; } }
                }
            }
            Rectangle {
                VerticalLayout {
                    padding: 24px;
                    spacing: 12px;
                    if (root.current-page == Page.apps) : AppsPageContainer {
                        add-app => { root.add-app(); }
                        delete-app(idx) => { root.delete-app(idx); }
                    }
                    if (root.current-page == Page.extensions) : ExtensionsPage { }
                    if (root.current-page == Page.protocols) : ProtocolsPage { }
                    if (root.current-page == Page.management) : ManagementPage {
                        dirty: root.dirty;
                        apply => { root.apply(); }
                        unregister => { root.unregister(); }
                        doctor => { root.doctor(); }
                        backup => { root.backup(); }
                        restore => { root.restore(); }
                        save-config => {
                            root.dirty = false;
                            root.save-config();
                        }
                    }
                }
            }
        }
        Rectangle {
            height: 32px;
            background: #f9f9f9;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 4px;
                padding-bottom: 4px;
                Text { text: root.config-path; font-size: 11px; color: #999999; }
                Text {
                    text: root.dirty ? " (未保存)" : " (保存済)";
                    font-size: 11px;
                    color: root.dirty ? #e08000 : #88aa88;
                }
            }
        }
    }
}
